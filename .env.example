# ==============================================================================
# CoESCD — Environment Configuration
# Copy to .env and fill in secret values.
# Variables without [OPTIONAL] are required for the app to start.
# ==============================================================================

# ── General ───────────────────────────────────────────────────────────────────
NODE_ENV=development                        # development | staging | production
LOG_LEVEL=debug                             # trace | debug | info | warn | error
SERVICE_VERSION=0.1.0
APP_URL=http://localhost:3000               # Public-facing URL (used in emails, links)

# App service ports
APP_PORT_WEB=3000
APP_PORT_API=3001
APP_PORT_REALTIME=3002
APP_PORT_SFU=3003                          # mediasoup signaling (ws://localhost:3003)
APP_PORT_WORKERS=3004                      # Workers metrics/health endpoint

# ── Database (PostgreSQL 17 + PostGIS 3.5) ────────────────────────────────────
# Apps MUST connect via PgBouncer (transaction mode). Direct URL is for
# migrations only (TypeORM migration runner bypasses the pooler).
DATABASE_URL=postgresql://postgres:dev@localhost:6432/coescd_dev
DATABASE_DIRECT_URL=postgresql://postgres:dev@localhost:5432/coescd_dev

DATABASE_HOST=localhost
DATABASE_PORT=6432                         # PgBouncer port — NOT 5432
DATABASE_USER=postgres
DATABASE_PASSWORD=dev
DATABASE_NAME=coescd_dev
DATABASE_SSL=false                         # true in production (verify-full)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_STATEMENT_TIMEOUT=30000           # ms — matches analyst query timeout
DATABASE_IDLE_TIMEOUT=600000               # ms

# ── Redis 7.4 ─────────────────────────────────────────────────────────────────
# Single instance in dev; Redis CoESCD (3 nodes) in production.
# Roles: PDP cache, sessions, counters, pub/sub, presence, rate limiting.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=                            # empty in dev
REDIS_TLS=false                            # true in production

# Logical DB separation (prevent key collisions between roles)
REDIS_DB_CACHE=0                           # PDP decisions, hot counters
REDIS_DB_SESSIONS=1                        # Refresh token metadata
REDIS_DB_RATELIMIT=2                       # Token bucket state
REDIS_DB_PRESENCE=3                        # User online presence

# ── NATS JetStream ────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_USER=                                 # empty in dev
NATS_PASSWORD=                             # empty in dev
NATS_TLS=false

# Stream names (must match consumer config in shared/events)
NATS_STREAM_IAM=STREAM_IAM
NATS_STREAM_INCIDENT=STREAM_INCIDENT
NATS_STREAM_TASK=STREAM_TASK
NATS_STREAM_CHAT=STREAM_CHAT
NATS_STREAM_FILE=STREAM_FILE
NATS_STREAM_GEO=STREAM_GEO
NATS_STREAM_NOTIFICATION=STREAM_NOTIFICATION
NATS_STREAM_ANALYTICS=STREAM_ANALYTICS
NATS_STREAM_AUDIT=STREAM_AUDIT

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
# Bucket names must match those created by minio-init in docker-compose.yml.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=coescd
S3_SECRET_KEY=coescd_dev
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true                   # required for MinIO

S3_BUCKET_FILES=coescd-dev-files         # user-uploaded files
S3_BUCKET_DOCUMENTS=coescd-dev-documents # generated PDFs / reports
S3_BUCKET_MEDIA=coescd-dev-media         # voice / video recordings
S3_BUCKET_AUDIT=coescd-audit             # WORM audit artifacts (cross-tenant)
S3_BUCKET_TEMP=coescd-temp               # temporary processing (24h TTL)
S3_BUCKET_BACKUPS=coescd-backups         # database snapshots

# ── OpenSearch 2.17 ───────────────────────────────────────────────────────────
OPENSEARCH_NODE=http://localhost:9200
OPENSEARCH_USERNAME=                       # empty in dev (security disabled)
OPENSEARCH_PASSWORD=
OPENSEARCH_TLS=false

# Index names
OPENSEARCH_INDEX_INCIDENTS=incidents
OPENSEARCH_INDEX_MESSAGES=messages
OPENSEARCH_INDEX_DOCUMENTS=documents
OPENSEARCH_INDEX_AUDIT_PREFIX=audit-       # ILM-managed: audit-2026.04 etc.

# ── Authentication — JWT (RS256 asymmetric) ───────────────────────────────────
# Production: generate RSA-4096 key pair and set the PEM paths or base64 values.
# Dev shortcut: use symmetric HS256 by setting JWT_DEV_SYMMETRIC=true and
#   providing JWT_ACCESS_SECRET / JWT_REFRESH_SECRET instead of key files.
#   NEVER use symmetric mode in staging or production.
JWT_DEV_SYMMETRIC=true                     # false in staging / production

# Dev only (ignored when JWT_DEV_SYMMETRIC=false)
JWT_ACCESS_SECRET=dev-access-secret-min-32-chars-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-min-32-chars-change-me

# Production only (ignored when JWT_DEV_SYMMETRIC=true)
# JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem

JWT_ACCESS_EXPIRY=10m                      # docs: 10-minute access token
JWT_REFRESH_EXPIRY=8h                      # docs: 8-hour refresh token
JWT_ISSUER=coescd
JWT_AUDIENCE=coescd-clients

# ── Cookie & Session ──────────────────────────────────────────────────────────
COOKIE_SECRET=dev-cookie-secret-change-in-production
COOKIE_SECURE=false                        # true in production (HTTPS only)
COOKIE_SAME_SITE=lax                       # strict in production
COOKIE_DOMAIN=localhost

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000         # comma-separated list in production

# ── WebSocket (Socket.IO realtime gateway) ────────────────────────────────────
WS_CORS_ORIGINS=http://localhost:3000
WS_PING_INTERVAL=25000                     # ms
WS_PING_TIMEOUT=5000                       # ms
WS_MAX_BUFFER_SIZE=10485760                # 10 MB

# ── Rate Limiting (@nestjs/throttler) ─────────────────────────────────────────
THROTTLE_TTL=60000                         # ms window
THROTTLE_LIMIT_READ=600                    # requests per window (authenticated reads)
THROTTLE_LIMIT_WRITE=120                   # requests per window (authenticated writes)
THROTTLE_LIMIT_AUTH=5                      # login / MFA attempts per window

# ── Password Hashing (argon2id) ───────────────────────────────────────────────
ARGON2_MEMORY_COST=65536                   # 64 MB
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ── MFA / TOTP ────────────────────────────────────────────────────────────────
MFA_ISSUER=CoESCD
MFA_WINDOW=1                               # allow 1 period drift (±30s)

# ── File Uploads & Virus Scanning ─────────────────────────────────────────────
FILE_MAX_SIZE_BYTES=524288000              # 500 MB (system-design §7.4: 500 MB limit)
FILE_UPLOAD_CONCURRENCY=5

# ClamAV daemon — installed via docker-compose, port 3310
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=60000                       # ms — allow time for large file scans

# ── Email (SMTP via Mailpit in dev) ───────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@coescd.local
SMTP_FROM_NAME=CoESCD Platform
SMTP_TLS=false                             # true in production

# ── Push Notifications [OPTIONAL] ─────────────────────────────────────────────
# FCM_SERVER_KEY=
# APNS_KEY_PATH=/run/secrets/apns.p8
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_TOPIC=kg.coescd.app
# APNS_PRODUCTION=false

# ── SMS [OPTIONAL] ────────────────────────────────────────────────────────────
# SMS_PROVIDER=mock                        # twilio | vonage | mock
# SMS_ACCOUNT_SID=
# SMS_AUTH_TOKEN=
# SMS_FROM_NUMBER=

# ── SSO / OIDC [OPTIONAL] ─────────────────────────────────────────────────────
# OIDC_ISSUER_URL=http://localhost:8080/realms/coescd   # Keycloak dev realm
# OIDC_CLIENT_ID=coescd-api
# OIDC_CLIENT_SECRET=

# ── mediasoup SFU ─────────────────────────────────────────────────────────────
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=127.0.0.1           # public IP / domain in production
MEDIASOUP_RTP_MIN_PORT=40000
MEDIASOUP_RTP_MAX_PORT=49999
MEDIASOUP_NUM_WORKERS=4                    # set to CPU core count in production

# ── External Integrations [OPTIONAL] ─────────────────────────────────────────
# WEATHER_API_URL=
# WEATHER_API_KEY=
# SEISMIC_FEED_URL=                        # FDSN-compliant endpoint
# CAP_FEED_URL=                            # Common Alerting Protocol feed

# ── Swagger / OpenAPI ─────────────────────────────────────────────────────────
SWAGGER_ENABLED=true                       # false in production
SWAGGER_PATH=api/docs

# ── Observability ─────────────────────────────────────────────────────────────
# OpenTelemetry — sends traces to Jaeger (start with --profile observability)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=coescd-api             # override per service: coescd-realtime, etc.

# Prometheus metrics endpoint (scraped by prometheus container)
METRICS_ENABLED=true
METRICS_PATH=/metrics

# ── Dev Seed Credentials ──────────────────────────────────────────────────────
# Used by tools/migrations/init.sql seed and the admin panel first login.
SEED_ADMIN_EMAIL=admin@coescd.local
SEED_ADMIN_PASSWORD=Admin123!
SEED_TENANT_CODE=tj-dushanbe
SEED_TENANT_NAME=Dushanbe National HQ
SEED_ADMIN_ROLES=platform_admin,tenant_admin
SEED_ADMIN_ENABLED=true
